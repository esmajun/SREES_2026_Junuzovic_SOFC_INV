\begin_layout Subsection
Nernst napon
\end_layout

\begin_layout Standard
Reversibilni napon SOFC opisan je Nernst jednadžbom:
\end_layout

\begin_layout Standard
V_Nernst = E0 + (RT/2F) * ln(pH2 * sqrt(pO2) / pH2O)
\end_layout

\begin_layout Standard
gdje je:
\end_layout

\begin_layout Standard
- E0 = 1.229 V (standardni reversibilni napon)
\end_layout

\begin_layout Standard
- R = 8.314 J/mol/K (univerzalna plinska konstanta)
\end_layout

\begin_layout Standard
- T = radna temperatura [K]
\end_layout

\begin_layout Standard
- F = 96485 C/mol (Faradayeva konstanta)
\end_layout

\begin_layout Standard
- pH2,
 pO2,
 pH2O = parcijalni pritisci [atm]
\end_layout

\begin_layout Subsection
Gubici napona
\end_layout

\begin_layout Standard
Ukupni napon ćelije:
\end_layout

\begin_layout Standard
V_cell = V_Nernst - V_ohm - V_act
\end_layout

\begin_layout Standard
gdje je:
\end_layout

\begin_layout Standard
- V_ohm = I * Rint (ohmski gubitak)
\end_layout

\begin_layout Standard
- V_act = 0.1 * ln(1 + I/0.01) (aktivacijski gubitak)
\end_layout

