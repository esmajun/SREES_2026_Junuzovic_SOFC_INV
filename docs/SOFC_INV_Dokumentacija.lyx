\begin{equation}
V_{\mathrm{Nernst}}=E_{0}+\frac{RT}{2F}\ln\left(\frac{p_{H_{2}}\sqrt{p_{O_{2}}}}{p_{H_{2}O}}\right)
\end{equation}

\end_inset

gdje je:
\end_layout

